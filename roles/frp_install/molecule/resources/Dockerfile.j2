# Molecule managed Dockerfile template
# Base image from platform configuration
FROM {{ item.image | default('ubuntu:22.04') }}

# Set environment variables for non-interactive installation
ENV DEBIAN_FRONTEND=noninteractive

# Install required packages for Ansible testing
RUN apt-get update && \
    apt-get install -y \
        python3 \
        python3-pip \
        python3-dev \
        sudo \
        curl \
        wget \
        ca-certificates \
        systemd \
        systemd-sysv \
        init && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Create a non-root user for testing
RUN useradd -m -s /bin/bash ansible && \
    echo 'ansible ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/ansible && \
    chmod 0440 /etc/sudoers.d/ansible

# Set working directory
WORKDIR /opt

# Default command - can be overridden in molecule configuration
{% if item.command is defined %}
CMD {{ item.command }}
{% else %}
CMD ["sleep", "infinity"]
{% endif %}
