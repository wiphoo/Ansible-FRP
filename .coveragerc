[run]
source = tests
omit =
    */venv/*
    */.venv/*
    */__pycache__/*
    */migrations/*
    */.pytest_cache/*
    */.ansible/*
    */collections/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    class .*\bProtocol\):
    @(abc\.)?abstractmethod

[html]
directory = htmlcov
